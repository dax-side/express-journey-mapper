{
  "name": "express-journey-mapper",
  "version": "1.0.6",
  "description": "Generate user journey documentation for Express.js applications with deep code analysis, OpenAPI export, and service dependency mapping",
  "keywords": [
    "express",
    "documentation",
    "api",
    "journey",
    "flow",
    "mapper",
    "openapi",
    "swagger",
    "joi",
    "zod",
    "validation"
  ],
  "author": "Damola",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dax-side/express-journey-mapper.git"
  },
  "bugs": {
    "url": "https://github.com/dax-side/express-journey-mapper/issues"
  },
  "homepage": "https://github.com/dax-side/express-journey-mapper#readme",
  "bin": {
    "express-journey-mapper": "./dist/cli.js",
    "journey-map": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@babel/parser": "^7.23.0",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "glob": "^10.3.0",
    "ts-morph": "^21.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.25",
    "axios": "^1.13.2",
    "eslint": "^8.55.0",
    "express": "^5.2.1",
    "prettier": "^3.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
